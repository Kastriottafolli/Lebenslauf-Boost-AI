# ── Lebenslauf Boost AI — Konfiguration / Configuration ──
# Standard = Bring-your-own-key: Nutzer geben ihren Key in der UI ein.
# Diese Server-Keys sind OPTIONAL und nur ein Fallback, wenn ALLE denselben
# Key nutzen sollen. Leer lassen für den BYOK-Modus.
#
# Default = bring-your-own-key: users enter their key in the UI. These
# server keys are OPTIONAL fallbacks. Leave empty for BYOK mode.

# Anthropic Claude (Anbieter 1 / Provider 1)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI GPT (Anbieter 2 / Provider 2)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
# Wenn ein OpenAI-Key gesetzt ist, nutzt das RAG echte Embeddings.
# Ohne Key fällt es automatisch auf TF-IDF zurück (offline, kostenlos).
RAG_TOP_K=5

# App
MAX_UPLOAD_MB=10
